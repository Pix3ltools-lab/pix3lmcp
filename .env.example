# URL base di pix3lboard
PIX3LBOARD_URL=http://localhost:3000

# Autenticazione — scegliere UNA delle due opzioni:

# Opzione 1 (preferita): API Key — generata da pix3lboard > UserMenu > API Keys
PIX3LBOARD_API_KEY=

# Opzione 2 (fallback): Email + Password — solo Docker, non Vercel
PIX3LBOARD_EMAIL=
PIX3LBOARD_PASSWORD=

# Workspace IDs disponibili (comma-separated, visibili nell'URL di pix3lboard)
WORKSPACE_IDS=

# Porta HTTP del server MCP (solo Docker)
PORT=3010
